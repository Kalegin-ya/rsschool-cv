# https://editorconfig.org

# special property that should be specified at the top of the file
# outside of any sections. Set to true to stop .editorconfig files
# search on current file.
root = true

# Matches any string of characters, except path separators
[*]
charset = utf-8 #format coddig

# set to lf, cr, or crlf to control how line breaks are represented.
end_of_line = lf

# a whole number defining the number of columns used for each indentation level
# and the width of soft tabs (when supported). When set to tab, the value of
# tab_width (if specified) will be used.
indent_size = 2

# set to tab or space to use hard tabs or soft tabs respectively.
indent_style = space

# set to true to ensure file ends with a newline when saving and false to ensure it doesn't.
insert_final_newline = true

#max rows length
max_line_length = 80

# set to true to remove any whitespace characters preceding newline characters
# and false to ensure it doesn't.
trim_trailing_whitespace = true #подрезает концевые пробелы

#Exeptions
[*.md]
max_line_length = 0
trim_trailing_whitespace = false # последняя строка добавялется пустая по умолчанию

[COMMIT_EDITMSG]
max_line_length = 0
